# Public Supabase URL + anon key only (this app does not use the service role).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: partner playground at /demo — register the client in Supabase Dashboard (Auth → OAuth Apps)
# or CI using the Admin API; never commit the client secret to git.
NEXT_PUBLIC_DEMO_OAUTH_CLIENT_ID=
DEMO_OAUTH_CLIENT_SECRET=

# Optional: exact redirect URI for /demo if it must differ from window.location.origin
# NEXT_PUBLIC_DEMO_OAUTH_REDIRECT_URI=https://auth.yourdomain.com/demo/callback
