# Server-side only (HTTP MCP). Copy to .env.local — do not commit.
# Cursor needs no tokens here when using mcp-remote + OAuth (see README).

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# HTTP server
# PORT=3765
# Claude Code project .mcp.json uses this full MCP URL (override host/port/path):
# WORKORDER_SYSTEMS_MCP_URL=http://127.0.0.1:3765/mcp
# WORKORDER_SYSTEMS_PUBLIC_ORIGIN=https://your-mcp-host.example.com
# SUPABASE_JWT_AUD=authenticated

# --- Optional: stdio MCP or mcp:oauth-login CLI only ---
# WORKORDER_SYSTEMS_ACCESS_TOKEN=
# WORKORDER_SYSTEMS_REFRESH_TOKEN=
