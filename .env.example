# Supabase (required for tests and apps)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Local Edge Functions (optional): supabase functions serve --env-file .env.local --no-verify-jwt
# ingest-meter-reading expects SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY in that environment.
