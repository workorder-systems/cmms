# Supabase (required for tests and apps)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Similar Past Fixes Edge Functions (optional)
# Set OPENAI_API_KEY to run the E2E test (backfill + search). Indexing is server-only.
# Run: pnpm run supabase:functions (loads .env.local, skips JWT verify for local ES256 fix)
OPENAI_API_KEY=sk-..
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL_VERSION=v1

# Backfill function only (optional)
BACKFILL_BATCH_LIMIT=50
CRON_SECRET=your-cron-secret-for-x-cron-secret-header
