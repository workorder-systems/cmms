{
  "name": "database",
  "version": "1.0.0",
  "description": "Supabase database with TypeScript tests",
  "type": "module",
  "private": true,
  "workspaces": ["packages/sdk"],
  "dependencies": {
    "@db/sdk": "workspace:*"
  },
  "scripts": {
    "test": "vitest run",
    "test:db": "vitest run --exclude tests/sdk.test.ts",
    "test:sdk": "vitest run tests/sdk.test.ts",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "test:setup": "supabase start && npm run test",
    "test:teardown": "supabase stop",
    "gen-types": "bash packages/sdk/scripts/gen-types.sh"
  },
  "keywords": ["supabase", "postgres", "cmms", "work-orders", "multi-tenant", "rls"],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@supabase/supabase-js": "^2.39.3",
    "@types/node": "^20.11.5",
    "dotenv": "^16.4.5",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
