# Copy to `.env` in this directory (do not commit; see `.gitignore`).
#
# Load order:
# - Webhook receiver (`pnpm dev`): `plugins/example/.env.local` then `.env`
# - `pnpm smoke:setup`: repo root `.env.local` / `.env`, then this package’s
#   `.env.local` / `.env` (later overrides — use here for plugin-only overrides)

# --- Webhook receiver (src/server.ts) ---

# TCP port for GET /health, POST /webhook, GET /events
# PORT=8765

# HMAC-SHA256 shared secret (plaintext). Must match the Vault secret used for the
# plugin installation (same value as EXAMPLE_HMAC_SECRET for smoke:setup).
# Leave unset to accept unsigned webhooks (local debugging only).
# WEBHOOK_SECRET=example-plugin-dev-hmac-secret-key-32chars!!

# Directory for events.jsonl (default: ./data under this package)
# DATA_DIR=./data

# --- smoke:setup script (scripts/smoke-setup.ts) ---
# Usually set in repository root `.env.local` (see root `.env.example`).

# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Vault secret plaintext (must match WEBHOOK_SECRET on the receiver when verifying)
# EXAMPLE_HMAC_SECRET=example-plugin-dev-hmac-secret-key-32chars!!

# URL pg_net will POST to (must be reachable from the Supabase DB container)
# EXAMPLE_WEBHOOK_URL=http://host.docker.internal:8765/webhook

# Docker container name for `docker exec … psql` (Vault seeding)
# SUPABASE_DB_CONTAINER=supabase_db_database

# Legacy names (still read if EXAMPLE_* unset):
# EXAMPLE_PLUGIN_HMAC_SECRET=
# EXAMPLE_PLUGIN_WEBHOOK_URL=
